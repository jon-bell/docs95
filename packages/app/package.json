{
  "name": "@word/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main/index.cjs",
  "description": "A desktop word processor with feature-parity to Microsoft Word 95.",
  "author": {
    "name": "Word Contributors",
    "email": "word@example.com"
  },
  "homepage": "https://github.com/example/word",
  "scripts": {
    "build": "tsc -b && vite build && node scripts/build-preload.mjs",
    "dev": "cross-env NODE_ENV=development electron-forge start || vite",
    "dev:renderer": "vite",
    "dev:main": "tsc -b -w",
    "dev:electron": "electron .",
    "e2e": "playwright test",
    "icon": "node build/make-icon.mjs",
    "stage": "node scripts/stage-dist.mjs",
    "dist": "pnpm stage && electron-builder --publish never",
    "dist:mac": "pnpm stage && electron-builder --mac --publish never",
    "dist:win": "pnpm stage && electron-builder --win --publish never",
    "dist:linux": "pnpm stage && electron-builder --linux --publish never",
    "dist:all": "pnpm stage && electron-builder --mac --win --linux --publish never",
    "clean": "rm -rf dist out tsconfig.tsbuildinfo release release-staging"
  },
  "dependencies": {
    "@word/docx": "workspace:*",
    "@word/domain": "workspace:*",
    "@word/engine": "workspace:*",
    "@word/ipc-schema": "workspace:*",
    "@word/layout": "workspace:*",
    "@word/render": "workspace:*",
    "@word/shell": "workspace:*",
    "@word/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "electron": "^31.4.0",
    "electron-builder": "^25",
    "playwright": "^1.47.1",
    "vite": "^5.4.6"
  }
}
